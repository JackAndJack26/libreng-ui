{
    "name": "@libreng/themes",
    "version": "22.0.0",
    "author": "LibreNG UI Contributors",
    "description": "",
    "homepage": "https://github.com/JackAndJack26/libreng-ui/",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/JackAndJack26/libreng-ui.git",
        "directory": "packages/themes"
    },
    "bugs": {
        "url": "https://github.com/JackAndJack26/libreng-ui/issues"
    },
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./*": "./src/presets/*/index.ts",
        "./types": "./types/index.d.ts",
        "./types/*": "./types/*/index.d.ts",
        "./tokens": "./src/tokens/index.ts"
    },
    "publishConfig": {
        "main": "./index.mjs",
        "module": "./index.mjs",
        "types": "./index.d.mts",
        "exports": {
            ".": {
                "types": "./index.d.mts",
                "import": "./index.mjs",
                "default": "./index.mjs"
            },
            "./*": {
                "types": "./*/index.d.ts",
                "import": "./*/index.mjs",
                "default": "./*/index.mjs"
            },
            "./types": {
                "types": "./types/index.d.ts"
            },
            "./types/*": {
                "types": "./types/*/index.d.ts"
            }
        },
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && tsup && pnpm run build:postbuild",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "build:docs": "node ./scripts/build-docs.ts",
        "dev:link": "pnpm link --global && npm link"
    },
    "dependencies": {
        "@primeuix/styled": "catalog:"
    }
}
