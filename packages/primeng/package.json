{
    "name": "@libreng/ui",
    "version": "22.0.0",
    "author": "LibreNG UI Contributors",
    "description": "LibreNG UI is an open source UI library for Angular featuring a rich set of 80+ components, based on the MIT-licensed PrimeNG v21 by PrimeTek.",
    "homepage": "https://github.com/capivaramu/orbia-ui/",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/capivaramu/orbia-ui.git",
        "directory": "packages/primeng"
    },
    "bugs": {
        "url": "https://github.com/capivaramu/orbia-ui/issues"
    },
    "keywords": [
        "libreng-ui",
        "angular",
        "ui library",
        "component library",
        "material",
        "bootstrap",
        "fluent",
        "tailwind"
    ],
    "publishConfig": {
        "directory": "dist",
        "linkDirectory": false,
        "access": "public"
    },
    "scripts": {
        "build": "cross-env NODE_ENV=production INPUT_DIR=src/ OUTPUT_DIR=dist/ pnpm run build:package",
        "build:package": "pnpm run build:prebuild && ng build libreng-ui && pnpm run build:postbuild",
        "build:prebuild": "node ./scripts/prebuild.mjs",
        "build:postbuild": "node ./scripts/postbuild.mjs",
        "dev:link": "pnpm link --global && npm link",
        "lint": "ng lint",
        "test:unit": "ng test libreng-ui --watch=false --browsers=ChromeHeadless",
        "test:unit:watch": "ng test libreng-ui",
        "test:unit:coverage": "ng test libreng-ui --coverage"
    },
    "devDependencies": {
        "karma": "~6.4.4",
        "karma-chrome-launcher": "~3.2.0",
        "karma-coverage": "~2.2.1",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.1.0",
        "tslib": "^2.8.1"
    },
    "peerDependencies": {
        "@angular/cdk": "catalog:angular22",
        "@angular/common": "catalog:angular22",
        "@angular/core": "catalog:angular22",
        "@angular/forms": "catalog:angular22",
        "@angular/router": "catalog:angular22",
        "@angular/platform-browser": "catalog:angular22",
        "rxjs": "^6.0.0 || ^7.8.1"
    },
    "dependencies": {
        "@primeuix/styled": "catalog:",
        "@primeuix/utils": "catalog:",
        "@primeuix/styles": "catalog:",
        "@primeuix/motion": "catalog:"
    }
}
